# ── Secrets & credentials ────────────────────────────────────────────────────
# NEVER commit API keys, tokens, or any credentials
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
*.pfx
credentials.json
secrets.json
secrets.toml
service_account*.json

# Streamlit secrets (API keys entered via secrets.toml)
.streamlit/secrets.toml
.streamlit/credentials.toml

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Build / packaging
build/
dist/
wheels/
*.egg-info/
*.egg
MANIFEST

# Testing
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv
venv/
env/
ENV/

# ── Test output files ────────────────────────────────────────────────────────
tests/test_output.docx
tests/test_output.pdf
tests/*.docx
tests/*.pdf

# ── Uploaded / temporary audio and video files ───────────────────────────────
# Temp chunks created during transcription
tmp*/
temp/
*.tmp

# Do NOT ignore source audio/video assets intentionally committed to the repo.
# If you need to commit test fixtures, add them explicitly with git add -f.

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDEs & editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── uv ───────────────────────────────────────────────────────────────────────
# .venv is excluded above.
# uv.lock IS committed — it ensures reproducible installs across machines.